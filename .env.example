# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Facebook Configuration (US Audience Page)
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_PAGE_ID=your_facebook_page_id_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_PHOTO_FOLDER_ID=your_photo_folder_id_here

# YouTube Configuration
YOUTUBE_TOKEN_JSON=your_youtube_token_json_here

# ============================================
# US AUDIENCE CONFIGURATION
# ============================================

# Translation: Auto-translate Chinese videos to English
ENABLE_TRANSLATION=true

# TTS Voice (English)
# Options: en-US-ChristopherNeural, en-US-GuyNeural, en-US-JennyNeural, en-GB-SoniaNeural
TTS_VOICE=en-US-ChristopherNeural

# Subtitle language
# Options: english, chinese, dual (both languages)
SUBTITLE_LANGUAGE=dual

# SEO Language (English for US audience)
SEO_LANGUAGE=en-US

# Time zone for scheduling
# System automatically uses US Eastern Time (America/New_York)
# Peak hours: 7-9AM, 12-1PM, 5-9PM, 10-11PM EST

# Content Source (Chinese video platforms)
# Options: weibo, douyin, bilibili, kuaishou
CHINESE_CONTENT_SOURCE=douyin

# Content Category
# Options: music, food, travel, comedy, culture, wildlife, nature
CHINESE_CONTENT_CATEGORY=culture

# Target Market
CHINESE_TARGET_REGION=united_states
